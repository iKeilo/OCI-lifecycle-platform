PORT=8080
STATIC_DIR=
OCI_EXECUTION_MODE=oci

# PostgreSQL is optional in local engineering mode. Set this to enable migrations.
DATABASE_URL=postgres://oci_lifecycle:oci_lifecycle@localhost:5432/oci_lifecycle?sslmode=disable

# Required only when storing inline OCI PEM private keys in the profiles table.
# Must be exactly 32 raw bytes or a base64 encoded 32-byte key.
PROFILE_KEY_ENCRYPTION_KEY=

# Optional local encrypted profile store for machines without PostgreSQL.
# Never commit this file; .runtime/ is gitignored.
PROFILE_STORE_FILE=.runtime/profiles.json

# Panel login. Use PANEL_PASSWORD_HASH in production; PANEL_PASSWORD is only a
# local bootstrap convenience and should not be committed.
PANEL_PASSWORD_HASH=
PANEL_PASSWORD=
PANEL_SESSION_SECRET=
PANEL_AUTH_DISABLED=false

# Real OCI mode requires these values.
OCI_TENANCY_OCID=
OCI_USER_OCID=
OCI_FINGERPRINT=
OCI_PRIVATE_KEY_FILE=
OCI_REGION=ap-chuncheon-1

# Optional SMTP notification delivery.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=false
SMTP_STARTTLS=true

# Optional notification webhook delivery.
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_SECRET=
