# OCI Lifecycle Platform Docker environment.
# Copy to /etc/oci-lifecycle-platform/docker.env or pass with:
# docker compose --env-file docker/.env up -d

COMPOSE_PROJECT_NAME=oci-lifecycle-platform
OCI_LIFECYCLE_IMAGE=oci-lifecycle-platform:local
WEB_PORT=18080
TZ=Asia/Shanghai

# Generated by scripts/docker-install.sh. Leave empty only for local build tests.
PANEL_PASSWORD_HASH=
PANEL_SESSION_SECRET=
PROFILE_KEY_ENCRYPTION_KEY=

# oci = use real OCI SDK calls with saved Web Profiles or env fallback credentials.
# local is only for developer UI/backend flow checks and must not be used for real API validation.
OCI_EXECUTION_MODE=oci

# Optional fallback OCI config. Prefer adding profiles from the Web UI.
# Mount PEM files under /etc/oci-lifecycle-platform/keys on host.
OCI_KEY_DIR=/etc/oci-lifecycle-platform/keys
OCI_TENANCY_OCID=
OCI_USER_OCID=
OCI_FINGERPRINT=
OCI_PRIVATE_KEY_PATH=
OCI_REGION=
OCI_COMPARTMENT_OCID=

# Optional PostgreSQL profile. Default app uses encrypted file storage in /data.
DATABASE_URL=
POSTGRES_DB=oci_lifecycle
POSTGRES_USER=oci_lifecycle
POSTGRES_PASSWORD=change-me-before-production
POSTGRES_PORT=5432

# Optional build proxy for Go modules, for example:
# GO_PROXY=https://goproxy.cn,direct
GO_PROXY=

PROFILE_DATA_VOLUME=oci-lifecycle-platform-profile-data
POSTGRES_DATA_VOLUME=oci-lifecycle-platform-postgres-data
